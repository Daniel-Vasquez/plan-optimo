---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

export interface Props {
  title?: string;
  currentPage?: string;
}
const { title = 'TrackFit', currentPage = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="es" class="bg-base text-primary font-body">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title} · TrackFit</title>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0d0f14" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="TrackFit" />
  <link rel="apple-touch-icon" href="/icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <slot name="head" />
  <ViewTransitions />
</head>
<body
  class="bg-base min-h-screen font-body"
  x-data="onboardingState()"
  x-init="init()"
>
  <!-- Onboarding Modal -->
  <div
    x-show="showOnboarding"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100"
    class="fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm p-4"
  >
    <div
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 scale-95"
      x-transition:enter-end="opacity-100 scale-100"
      class="bg-surface border border-border2 rounded-2xl p-8 w-full max-w-sm"
    >
      <h2 class="font-display text-4xl text-yellow mb-1">TRACKFIT</h2>
      <p class="text-muted text-sm mb-6">Tu plan de 16 semanas comienza aquí.</p>

      <div class="space-y-4">
        <div>
          <label class="block text-xs text-muted mb-1 uppercase tracking-wider">Tu nombre</label>
          <input
            type="text"
            x-model="name"
            placeholder="Ej. Daniel"
            class="w-full bg-surface2 border border-border2 rounded-lg px-4 py-3 text-primary placeholder-muted2 focus:outline-none focus:border-yellow transition-colors"
          />
        </div>
        <div>
          <label class="block text-xs text-muted mb-1 uppercase tracking-wider">Inicio del plan</label>
          <input
            type="date"
            x-model="startDate"
            class="w-full bg-surface2 border border-border2 rounded-lg px-4 py-3 text-primary focus:outline-none focus:border-yellow transition-colors"
          />
        </div>
        <p x-show="error" class="text-orange text-sm" x-text="error"></p>
        <button
          @click="submit()"
          class="w-full bg-yellow text-base font-bold py-3 rounded-lg hover:bg-yellow/90 active:scale-95 transition-all"
        >
          Empezar plan
        </button>
      </div>
    </div>
  </div>

  <!-- Layout wrapper -->
  <div class="flex min-h-screen">
    <!-- Desktop Sidebar -->
    <aside class="hidden lg:flex flex-col w-60 bg-surface border-r border-border fixed top-0 left-0 h-full z-40">
      <div class="px-6 py-5 border-b border-border">
        <a href="/" class="font-display text-3xl text-yellow tracking-wider">TRACKFIT</a>
        <div id="sidebar-week-badge" class="mt-1 text-xs text-muted">Sem 1/16</div>
      </div>
      <nav class="flex-1 py-4 px-3">
        <a href="/" class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition-colors ${currentPage === 'dashboard' ? 'bg-surface2 text-primary' : 'text-muted hover:text-primary hover:bg-surface2'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/calendar" class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition-colors ${currentPage === 'calendar' ? 'bg-surface2 text-primary' : 'text-muted hover:text-primary hover:bg-surface2'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Calendario
        </a>
        <a href={`/day/?date=${new Date().toISOString().slice(0,10)}`} class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition-colors ${currentPage === 'today' ? 'bg-surface2 text-primary' : 'text-muted hover:text-primary hover:bg-surface2'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Hoy
        </a>
        <a href="/progress" class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition-colors ${currentPage === 'progress' ? 'bg-surface2 text-primary' : 'text-muted hover:text-primary hover:bg-surface2'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Progreso
        </a>
        <a href="/notes" class={`nav-link flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition-colors ${currentPage === 'notes' ? 'bg-surface2 text-primary' : 'text-muted hover:text-primary hover:bg-surface2'}`}>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          Notas
        </a>
      </nav>
    </aside>

    <!-- Main content -->
    <main class="flex-1 lg:ml-60 pb-24 lg:pb-6">
      <!-- Mobile header -->
      <header class="lg:hidden sticky top-0 z-30 bg-base/90 backdrop-blur-sm border-b border-border px-4 py-3 flex items-center justify-between">
        <a href="/" class="font-display text-2xl text-yellow tracking-wider">TRACKFIT</a>
        <span id="mobile-week-badge" class="text-xs bg-surface2 text-muted px-2 py-1 rounded-full">Sem 1/16</span>
      </header>

      <div class="animate-fade-in">
        <slot />
      </div>
    </main>
  </div>

  <!-- Mobile bottom nav -->
  <nav class="lg:hidden fixed bottom-0 left-0 right-0 z-40 bg-surface border-t border-border flex items-center justify-around px-2"
    style="padding-bottom: env(safe-area-inset-bottom);">
    <a href="/" class={`flex flex-col items-center gap-0.5 py-3 px-3 ${currentPage === 'dashboard' ? 'text-yellow' : 'text-muted'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      <span class="text-[10px]">Dashboard</span>
    </a>
    <a href="/calendar" class={`flex flex-col items-center gap-0.5 py-3 px-3 ${currentPage === 'calendar' ? 'text-yellow' : 'text-muted'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span class="text-[10px]">Calendario</span>
    </a>
    <a id="today-nav-link" href="/day/" class={`flex flex-col items-center gap-0.5 py-3 px-3 ${currentPage === 'today' ? 'text-yellow' : 'text-muted'}`}>
      <div class="bg-yellow rounded-full p-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-base" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <span class="text-[10px]">Hoy</span>
    </a>
    <a href="/progress" class={`flex flex-col items-center gap-0.5 py-3 px-3 ${currentPage === 'progress' ? 'text-yellow' : 'text-muted'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      <span class="text-[10px]">Progreso</span>
    </a>
    <a href="/notes" class={`flex flex-col items-center gap-0.5 py-3 px-3 ${currentPage === 'notes' ? 'text-yellow' : 'text-muted'}`}>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
      <span class="text-[10px]">Notas</span>
    </a>
  </nav>

  <script is:inline>
    function onboardingState() {
      return {
        showOnboarding: false,
        name: '',
        startDate: new Date().toISOString().slice(0, 10),
        error: '',
        init() {
          const config = this._getConfig();
          if (!config) {
            this.showOnboarding = true;
          } else {
            this._updateWeekBadge(config);
          }
          const todayLink = document.getElementById('today-nav-link');
          if (todayLink) {
            todayLink.href = '/day/?date=' + new Date().toISOString().slice(0, 10);
          }
        },
        submit() {
          if (!this.name.trim()) { this.error = 'Por favor ingresa tu nombre.'; return; }
          if (!this.startDate) { this.error = 'Por favor selecciona una fecha de inicio.'; return; }
          const config = { name: this.name.trim(), startDate: this.startDate };
          localStorage.setItem('trackfit_config', JSON.stringify(config));
          this.showOnboarding = false;
          this._updateWeekBadge(config);
        },
        _getConfig() {
          try { const item = localStorage.getItem('trackfit_config'); return item ? JSON.parse(item) : null; } catch { return null; }
        },
        _updateWeekBadge(config) {
          if (!config) return;
          const start = new Date(config.startDate + 'T00:00:00');
          const today = new Date(); today.setHours(0,0,0,0);
          const diff = Math.floor((today.getTime() - start.getTime()) / (1000*60*60*24));
          const week = Math.max(1, Math.min(16, Math.floor(diff/7)+1));
          const badge = 'Sem ' + week + '/16';
          const mb = document.getElementById('mobile-week-badge');
          const sb = document.getElementById('sidebar-week-badge');
          if (mb) mb.textContent = badge;
          if (sb) sb.textContent = badge;
        }
      };
    }

    // Re-run badge + today-link after every View Transition
    document.addEventListener('astro:page-load', function () {
      const todayLink = document.getElementById('today-nav-link');
      if (todayLink) {
        todayLink.href = '/day/?date=' + new Date().toISOString().slice(0, 10);
      }
      try {
        const cfg = JSON.parse(localStorage.getItem('trackfit_config') || 'null');
        if (!cfg) return;
        const start = new Date(cfg.startDate + 'T00:00:00');
        const now = new Date(); now.setHours(0,0,0,0);
        const diff = Math.floor((now.getTime() - start.getTime()) / (1000*60*60*24));
        const week = Math.max(1, Math.min(16, Math.floor(diff/7)+1));
        const badge = 'Sem ' + week + '/16';
        const mb = document.getElementById('mobile-week-badge');
        const sb = document.getElementById('sidebar-week-badge');
        if (mb) mb.textContent = badge;
        if (sb) sb.textContent = badge;
      } catch (_) {}
    });
  </script>

  <style is:global>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in { animation: fadeIn 0.2s ease-out; }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-slide-up { animation: slideUp 0.25s ease-out; }

    input[type="date"]::-webkit-calendar-picker-indicator {
      filter: invert(0.6);
    }

    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }
  </style>
</body>
</html>
