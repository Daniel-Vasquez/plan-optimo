---
export interface Props {
  label: string;
  value: string;
  unit?: string;
  accent?: string;
}
const { label, value, unit = '', accent = '' } = Astro.props;
---
<div class="bg-surface border border-border rounded-xl p-4 flex flex-col gap-1">
  <span class="text-xs text-muted uppercase tracking-wider">{label}</span>
  <div class="flex items-baseline gap-1 mt-1">
    <span class={`text-2xl font-bold ${accent || 'text-primary'}`}>{value}</span>
    {unit && <span class="text-sm text-muted">{unit}</span>}
  </div>
</div>
